# Server Configuration
PORT=5556
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=http://localhost:5555

# Database (Required - PostgreSQL only)
DATABASE_URL=postgresql://versus_user:dev_password@localhost:5433/versus_db

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# Monitoring (optional)
SENTRY_DSN=
APP_VERSION=2.0.0

# x402 Payment Integration
X402_ENABLED=false
X402_API_KEY=
X402_WEBHOOK_SECRET=
X402_BASE_URL=https://api.commerce.coinbase.com
X402_DEFAULT_AMOUNT_USD=1
X402_DEFAULT_CURRENCY=USD
X402_CALLBACK_URL=
X402_SETTLEMENT_ADDRESS=

# OpenClaw AI Agent Bridge
OPENCLAW_ENABLED=false
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_HOOK_TOKEN=
OPENCLAW_HOOK_PATH=/hooks

# Escrow Configuration
ESCROW_SIGNING_KEY=change-this-to-a-secure-random-key
