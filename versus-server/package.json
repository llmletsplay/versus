{
    "name":  "versus-server",
    "version":  "1.0.0",
    "description":  "Server and platform layer for the Versus reusable game packages",
    "main":  "dist/node.js",
    "type":  "module",
    "scripts":  {
                    "dev":  "tsx src/server/node.ts",
                    "build":  "bun build src/server/node.ts --outdir dist --target node",
                    "build:cloudflare":  "bun build src/server/cloudflare.ts --outdir dist/server --target browser",
                    "start":  "node dist/node.js",
                    "start:cloudflare":  "wrangler dev",
                    "deploy:cloudflare":  "wrangler deploy",
                    "mcp":  "bun run src/mcp/server.ts",
                    "test":  "node --no-warnings --experimental-vm-modules ../node_modules/jest/bin/jest.js --watchman=false --runInBand",
                    "test:watch":  "node --no-warnings --experimental-vm-modules ../node_modules/jest/bin/jest.js --watch --watchman=false --runInBand",
                    "lint":  "eslint .",
                    "lint:fix":  "eslint . --fix",
                    "type-check":  "tsc --noEmit",
                    "format":  "prettier --write .",
                    "format:check":  "prettier --check .",
                    "test:games":  "node --no-warnings --experimental-vm-modules ../node_modules/jest/bin/jest.js --config jest.games.config.js --watchman=false --runInBand"
                },
    "keywords":  [
                     "games",
                     "api",
                     "mcp",
                     "ai",
                     "arcade",
                     "typescript"
                 ],
    "author":  "",
    "license":  "MIT",
    "engines":  {
                    "node":  "\u003e=22.0.0",
                    "bun":  "\u003e=1.0.0"
                },
    "devDependencies":  {
                            "@types/better-sqlite3":  "^7.6.13",
                            "@types/bun":  "^1.2.18",
                            "@types/compression":  "^1.8.1",
                            "@types/hapi__shot":  "^6.0.0",
                            "@types/jest":  "^30.0.0",
                            "@types/jsonwebtoken":  "^9.0.10",
                            "@types/pg":  "^8.15.4",
                            "@types/supertest":  "^6.0.3",
                            "@types/ws":  "^8.18.1",
                            "@typescript-eslint/eslint-plugin":  "^8.35.1",
                            "@typescript-eslint/parser":  "^8.35.1",
                            "concurrently":  "^9.2.0",
                            "eslint":  "^9.30.1",
                            "eslint-config-prettier":  "^10.1.5",
                            "eslint-plugin-prettier":  "^5.5.1",
                            "globals":  "^16.4.0",
                            "husky":  "^9.1.7",
                            "jest":  "^30.0.4",
                            "lint-staged":  "^16.1.2",
                            "nodemon":  "^3.1.10",
                            "prettier":  "^3.6.2",
                            "supertest":  "^7.1.1",
                            "ts-jest":  "^29.4.0",
                            "typescript":  "^5.8.3"
                        },
    "dependencies":  {
                         "@modelcontextprotocol/sdk":  "^1.15.0",
                         "@types/uuid":  "^10.0.0",
                         "@x402/core":  "2.3.1",
                         "@x402/evm":  "2.3.1",
                         "@x402/fetch":  "2.3.0",
                         "@x402/hono":  "2.3.0",
                         "bcryptjs":  "^3.0.2",
                         "better-sqlite3":  "^12.2.0",
                         "dotenv":  "^17.0.1",
                         "jsonwebtoken":  "^9.0.2",
                         "pg":  "^8.16.3",
                         "uuid":  "^11.1.0",
                         "ws":  "^8.19.0",
                         "zod":  "^3.25.73",
                         "@llmletsplay/versus-battleship":  "file:../packages/battleship",
                         "@llmletsplay/versus-bingo":  "file:../packages/bingo",
                         "@llmletsplay/versus-blackjack":  "file:../packages/blackjack",
                         "@llmletsplay/versus-bullshit":  "file:../packages/bullshit",
                         "@llmletsplay/versus-catan":  "file:../packages/catan",
                         "@llmletsplay/versus-checkers":  "file:../packages/checkers",
                         "@llmletsplay/versus-chess":  "file:../packages/chess",
                         "@llmletsplay/versus-chinese-checkers":  "file:../packages/chinese-checkers",
                         "@llmletsplay/versus-connect-four":  "file:../packages/connect-four",
                         "@llmletsplay/versus-crazy-cards":  "file:../packages/crazy-cards",
                         "@llmletsplay/versus-cuttle":  "file:../packages/cuttle",
                         "@llmletsplay/versus-game-core":  "file:../packages/game-core",
                         "@llmletsplay/versus-go":  "file:../packages/go",
                         "@llmletsplay/versus-go-fish":  "file:../packages/go-fish",
                         "@llmletsplay/versus-hearts":  "file:../packages/hearts",
                         "@llmletsplay/versus-mahjong":  "file:../packages/mahjong",
                         "@llmletsplay/versus-mancala":  "file:../packages/mancala",
                         "@llmletsplay/versus-martial-tactics":  "file:../packages/martial-tactics",
                         "@llmletsplay/versus-omok":  "file:../packages/omok",
                         "@llmletsplay/versus-othello":  "file:../packages/othello",
                         "@llmletsplay/versus-poker":  "file:../packages/poker",
                         "@llmletsplay/versus-shogi":  "file:../packages/shogi",
                         "@llmletsplay/versus-spades":  "file:../packages/spades",
                         "@llmletsplay/versus-thirteen":  "file:../packages/thirteen",
                         "@llmletsplay/versus-tic-tac-toe":  "file:../packages/tic-tac-toe",
                         "@llmletsplay/versus-war":  "file:../packages/war",
                         "@llmletsplay/versus-word-tiles":  "file:../packages/word-tiles"
                     },
    "lint-staged":  {
                        "*.{ts,js}":  [
                                          "eslint --fix",
                                          "prettier --write"
                                      ],
                        "*.{json,md}":  [
                                            "prettier --write"
                                        ]
                    }
}
