{
  "name": "versus-server",
  "version": "1.0.0",
  "description": "Server and platform layer for the Versus reusable game packages",
  "main": "dist/node.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/node.ts",
    "build": "bun build src/server/node.ts --outdir dist --target node",
    "build:cloudflare": "bun build src/server/cloudflare.ts --outdir dist/server --target browser",
    "start": "node dist/node.js",
    "start:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "mcp": "bun run src/mcp/server.ts",
    "test": "/bin/zsh -lic 'NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" node ../node_modules/jest/bin/jest.js --watchman=false'",
    "test:watch": "/bin/zsh -lic 'NODE_OPTIONS=\"--experimental-vm-modules --no-warnings\" node ../node_modules/jest/bin/jest.js --watch --watchman=false'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "games",
    "api",
    "mcp",
    "ai",
    "arcade",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.18",
    "@types/compression": "^1.8.1",
    "@types/hapi__shot": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "@x402/core": "2.3.1",
    "@x402/evm": "2.3.1",
    "@x402/fetch": "2.3.0",
    "@x402/hono": "2.3.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "uuid": "^11.1.0",
    "ws": "^8.19.0",
    "zod": "^3.25.73",
    "@versus/against-cards": "workspace:*",
    "@versus/battleship": "workspace:*",
    "@versus/bingo": "workspace:*",
    "@versus/blackjack": "workspace:*",
    "@versus/bullshit": "workspace:*",
    "@versus/catan": "workspace:*",
    "@versus/checkers": "workspace:*",
    "@versus/chess": "workspace:*",
    "@versus/chinese-checkers": "workspace:*",
    "@versus/connect-four": "workspace:*",
    "@versus/crazy-cards": "workspace:*",
    "@versus/cuttle": "workspace:*",
    "@versus/game-core": "workspace:*",
    "@versus/go": "workspace:*",
    "@versus/go-fish": "workspace:*",
    "@versus/hearts": "workspace:*",
    "@versus/mahjong": "workspace:*",
    "@versus/mancala": "workspace:*",
    "@versus/martial-tactics": "workspace:*",
    "@versus/omok": "workspace:*",
    "@versus/othello": "workspace:*",
    "@versus/poker": "workspace:*",
    "@versus/shogi": "workspace:*",
    "@versus/spades": "workspace:*",
    "@versus/thirteen": "workspace:*",
    "@versus/tic-tac-toe": "workspace:*",
    "@versus/war": "workspace:*",
    "@versus/word-tiles": "workspace:*"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
