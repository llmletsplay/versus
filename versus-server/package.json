{
  "name": "versus-server",
  "version": "1.0.0",
  "description": "TypeScript game arcade API and MCP server for AI agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run src/server/node.ts",
    "dev:legacy": "nodemon --exec bun run src/index.ts",
    "build": "bun build src/server/node.ts --outdir dist --target node",
    "build:cloudflare": "bun build src/server/cloudflare.ts --outdir dist/server --target browser",
    "start": "node dist/node.js",
    "start:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "mcp": "bun run src/mcp/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "keywords": [
    "games",
    "api",
    "mcp",
    "ai",
    "arcade",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.16.3",
    "uuid": "^11.1.0",
    "zod": "^3.25.73"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.18",
    "@types/compression": "^1.8.1",
    "@types/hapi__shot": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.15.4",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "husky": "^9.1.7",
    "jest": "^30.0.4",
    "lint-staged": "^16.1.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
