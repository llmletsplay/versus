# Production Environment Configuration
# SECURITY: This file contains sensitive production values - DO NOT commit

# Server Configuration
NODE_ENV=production
SERVER_PORT=6789
CORS_ORIGIN=https://yourdomain.com
GAME_DATA_PATH=/app/game_data
LOG_LEVEL=info
MCP_PORT=4445

# SECURITY: JWT Secret - CRITICAL for authentication
# Generated with: openssl rand -hex 32
JWT_SECRET=4c80c3c4267315d200cae1ed81d5cfeefe18aa9c6552a71a3bb1c3ba81cb8b9a

# Database Configuration (PostgreSQL - Recommended for production)
DATABASE_URL=postgresql://versus_user:soOhB8Q9GAjsMtjbZ7JIz0ZX75HR6p/GiYHWIV+VJt8=@localhost:5432/versus_db
POSTGRES_DB=versus_db
POSTGRES_USER=versus_user
POSTGRES_PASSWORD=soOhB8Q9GAjsMtjbZ7JIz0ZX75HR6p/GiYHWIV+VJt8=
POSTGRES_PORT=5432

# Backup Configuration (CRITICAL for data protection)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/game_data/backups

# Monitoring (Essential for production)
# Get your DSN from sentry.io
SENTRY_DSN=
APP_VERSION=1.0.0

# Security Headers
ENABLE_HELMET=true
RATE_LIMIT_ENABLED=true

# Performance
ENABLE_COMPRESSION=true
MAX_REQUEST_SIZE=100kb
CONNECTION_TIMEOUT=30000

# SSL/TLS (Required for production)
HTTPS_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/versus.crt
SSL_KEY_PATH=/etc/ssl/private/versus.key

# Session Management
SESSION_SECRET=CHANGE_ME_GENERATE_NEW_SECRET
SESSION_TIMEOUT=86400000

# File Upload Limits
MAX_FILE_SIZE=10mb
UPLOAD_PATH=/app/uploads

# Redis (Recommended for production rate limiting and caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Stripe Payment Integration (Required for subscriptions)
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Email (For notifications, password reset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@yourdomain.com

# Analytics
GOOGLE_ANALYTICS_ID=
POSTHOG_API_KEY=

# Subscription Configuration
DEFAULT_SUBSCRIPTION_TIER=free
ENABLE_SUBSCRIPTION_MANAGEMENT=true
BILLING_WEBHOOK_ENDPOINT=/api/v1/payments/webhook/stripe

# Rate Limiting (Based on Redis if available)
USE_REDIS_RATE_LIMITING=true
RATE_LIMITS_GLOBAL=true
RATE_LIMITS_AUTH=true
RATE_LIMITS_API=true

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_GUEST_PLAYERS=true
ENABLE_ANALYTICS=true
ENABLE_SUBSCRIPTIONS=true
ENABLE_PAYMENTS=true
ENABLE_LEADERBOARDS=true
ENABLE_TOURNAMENTS=true
MAX_GAMES_PER_USER=100
MAINTENANCE_MODE=false

# Development Override (Set to false in production)
ALLOW_CORS_ANYWHERE=false
ENABLE_DEBUG_LOGGING=false
DISABLE_AUTH=false

# Pricing Configuration (USD/month)
BASIC_SUBSCRIPTION_PRICE=9.99
PRO_SUBSCRIPTION_PRICE=29.99
ENTERPRISE_SUBSCRIPTION_PRICE=99.99
TOURNAMENT_ENTRY_FEE=5.00