# Production Environment Configuration
# SECURITY: Copy this file and fill in real values. NEVER commit secrets.
# Use a secrets manager (e.g., Vault, AWS Secrets Manager, Doppler) in production.

# Server Configuration
NODE_ENV=production
SERVER_PORT=6789
CORS_ORIGIN=https://yourdomain.com
GAME_DATA_PATH=/app/game_data
LOG_LEVEL=info
MCP_PORT=4445

# SECURITY: JWT Secret — generate with: openssl rand -hex 32
# Must be at least 32 characters long
JWT_SECRET=

# Database Configuration (PostgreSQL — recommended for production)
DATABASE_URL=
POSTGRES_DB=versus_db
POSTGRES_USER=versus_user
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/game_data/backups

# Monitoring
SENTRY_DSN=
APP_VERSION=1.0.0

# Security Headers
ENABLE_HELMET=true
RATE_LIMIT_ENABLED=true

# Performance
ENABLE_COMPRESSION=true
MAX_REQUEST_SIZE=100kb
CONNECTION_TIMEOUT=30000

# SSL/TLS (Required for production)
HTTPS_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/versus.crt
SSL_KEY_PATH=/etc/ssl/private/versus.key

# Session Management
SESSION_SECRET=
SESSION_TIMEOUT=86400000

# File Upload Limits
MAX_FILE_SIZE=10mb
UPLOAD_PATH=/app/uploads

# x402 Payment Integration
X402_ENABLED=false
X402_API_KEY=
X402_WEBHOOK_SECRET=
X402_BASE_URL=https://api.commerce.coinbase.com
X402_DEFAULT_AMOUNT_USD=1
X402_DEFAULT_CURRENCY=USD
X402_CALLBACK_URL=https://yourdomain.com/payments/complete
X402_SETTLEMENT_ADDRESS=
