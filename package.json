{
    "name":  "versus",
    "version":  "1.0.0",
    "description":  "Package-first multiplayer game platform with reusable game engines, platform services, and experimental wagering layers",
    "private":  true,
    "type":  "module",
    "workspaces":  [
                       "packages/*",
                       "versus-server",
                       "versus-client",
                       "versus-skill"
                   ],
    "scripts":  {
                    "dev":  "concurrently \"bun run dev:server\" \"bun run dev:client\"",
                    "dev:server":  "cd versus-server \u0026\u0026 bun run dev",
                    "dev:client":  "cd versus-client \u0026\u0026 bun run dev",
                    "dev:docs":  "cd docs \u0026\u0026 mkdocs serve -a localhost:8000",
                    "build":  "npm run build:packages \u0026\u0026 bun run build:server \u0026\u0026 bun run build:client",
                    "build:server":  "cd versus-server \u0026\u0026 bun run build",
                    "build:client":  "cd versus-client \u0026\u0026 bun run build",
                    "test":  "npm run test:games",
                    "lint":  "npm --prefix versus-server run lint",
                    "type-check":  "npm --prefix versus-server run type-check",
                    "format":  "cd versus-server \u0026\u0026 bun run format",
                    "docker:up":  "docker-compose up -d",
                    "docker:down":  "docker-compose down",
                    "health":  "curl -f http://localhost:5556/api/v1/health | jq",
                    "metrics":  "curl -f http://localhost:5556/api/v1/metrics | jq",
                    "build:packages":  "node scripts/build-packages.mjs",
                    "test:games":  "npm --prefix versus-server run test:games"
                },
    "keywords":  [
                     "games",
                     "multiplayer",
                     "api",
                     "websocket",
                     "ai",
                     "mcp",
                     "chess",
                     "poker",
                     "typescript",
                     "react",
                     "bun"
                 ],
    "author":  "",
    "license":  "MIT",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/lightnolimit/versus.git"
                   },
    "engines":  {
                    "node":  "\u003e=22.0.0",
                    "bun":  "\u003e=1.0.0"
                },
    "devDependencies":  {
                            "concurrently":  "^9.1.0"
                        }
}
