{
  "name": "versus",
  "version": "1.0.0",
  "description": "AI-native competitive gaming arena with multiplayer games, AI agents, and crypto wagering",
  "private": true,
  "type": "module",
  "workspaces": [
    "versus-server",
    "versus-client"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "cd versus-server && bun run dev",
    "dev:client": "cd versus-client && bun run dev",
    "dev:docs": "cd docs && mkdocs serve -a localhost:8000",
    "build": "bun run build:server && bun run build:client",
    "build:server": "cd versus-server && bun run build",
    "build:client": "cd versus-client && bun run build",
    "test": "cd versus-server && bun test",
    "lint": "cd versus-server && bun run lint",
    "type-check": "cd versus-server && bun run type-check",
    "format": "cd versus-server && bun run format",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "health": "curl -f http://localhost:5556/api/v1/health | jq",
    "metrics": "curl -f http://localhost:5556/api/v1/metrics | jq"
  },
  "keywords": [
    "games",
    "multiplayer",
    "api",
    "websocket",
    "ai",
    "mcp",
    "chess",
    "poker",
    "typescript",
    "react",
    "bun"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lightnolimit/versus.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
