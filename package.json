{
  "name": "versus",
  "version": "1.0.0",
  "description": "A comprehensive multiplayer game platform with 27+ classic games, AI integration, and modern web technologies",
  "private": true,
  "type": "module",
  "workspaces": [
    "versus-server",
    "versus-client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:docs\"",
    "dev:server": "cd versus-server && bun run dev",
    "dev:client": "cd versus-client && bun run dev",
    "dev:docs": "serve docs -p 3001",
    "build": "npm run build:server && npm run build:client",
    "build:server": "cd versus-server && bun run build",
    "build:client": "cd versus-client && bun run build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:production": "./deploy.sh",
    "health:check": "curl -f http://localhost:6789/api/v1/health | jq",
    "metrics": "curl -f http://localhost:6789/api/v1/metrics | jq"
  },
  "keywords": [
    "games",
    "multiplayer",
    "api",
    "websocket",
    "ai",
    "mcp",
    "chess",
    "poker",
    "arcade",
    "typescript",
    "react",
    "bun",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/username/versus.git"
  },
  "bugs": {
    "url": "https://github.com/username/versus/issues"
  },
  "homepage": "https://github.com/username/versus#readme",
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "serve": "^14.2.4"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.3",
    "@hono/zod-validator": "^0.7.2",
    "@sentry/node": "^10.12.0",
    "@sentry/profiling-node": "^10.12.0",
    "hono": "^4.9.7"
  }
}
