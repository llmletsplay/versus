{
  "name": "versus",
  "version": "1.0.0",
  "description": "Standalone npm game package monorepo for llmletsplay",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "package-test-harness"
  ],
  "scripts": {
    "dev:docs": "cd docs && mkdocs serve -a localhost:8000",
    "build:packages": "node scripts/build-packages.mjs",
    "test": "npm run test:games",
    "test:games": "npm --prefix package-test-harness run test:games",
    "lint": "npm --prefix package-test-harness run lint",
    "type-check": "npm --prefix package-test-harness run type-check",
    "format": "npm --prefix package-test-harness run format",
    "docs:packages": "node scripts/sync-package-docs.mjs",
    "check:packages": "node scripts/check-package-release.mjs",
    "release:packages": "npm run build:packages && npm run check:packages && npm run test:games",
    "pack:packages": "node scripts/publish-packages.mjs --dry-run",
    "publish:packages:dry-run": "npm run release:packages && npm run pack:packages",
    "publish:packages": "npm run release:packages && node scripts/publish-packages.mjs"
  },
  "keywords": [
    "games",
    "game-engines",
    "npm",
    "chess",
    "poker",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/llmletsplay/versus.git"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
