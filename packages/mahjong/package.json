{
  "name": "@llmletsplay/versus-mahjong",
  "version": "0.1.1",
  "description": "Standalone Versus mahjong engine package",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
