{
  "name": "@llmletsplay/versus-game-core",
  "version": "0.1.1",
  "description": "Shared core types and helpers for standalone Versus game packages",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
