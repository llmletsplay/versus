{
  "name": "Versus Game Platform",
  "description": "Enterprise-grade multiplayer game server with 27+ classic games, JWT auth, and PostgreSQL. Production-ready with monitoring, backups, and security hardening.",
  "repository": "https://github.com/lightnolimit/versus",
  "logo": "https://raw.githubusercontent.com/lightnolimit/versus/main/docs/logo.png",
  "tags": [
    "game-server",
    "api",
    "multiplayer",
    "chess",
    "poker",
    "typescript",
    "hono",
    "ai-agents"
  ],
  "services": [
    {
      "name": "versus-server",
      "source": {
        "repo": "lightnolimit/versus",
        "branch": "main"
      },
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd versus-server && bun install && bun run build",
        "watchPatterns": [
          "versus-server/**"
        ]
      },
      "deploy": {
        "startCommand": "cd versus-server && node dist/server/node.js",
        "healthcheckPath": "/api/v1/health",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
      },
      "env": {
        "NODE_ENV": {
          "description": "Node environment",
          "default": "production"
        },
        "PORT": {
          "description": "Server port (Railway auto-assigns)",
          "default": "6789",
          "generator": {
            "type": "PORT"
          }
        },
        "JWT_SECRET": {
          "description": "JWT secret key for authentication (REQUIRED - generate with: openssl rand -hex 32)",
          "generator": {
            "type": "SECRET",
            "length": 64
          }
        },
        "CORS_ORIGIN": {
          "description": "Allowed CORS origin (your frontend URL or * for development)",
          "default": "*"
        },
        "LOG_LEVEL": {
          "description": "Log level (debug, info, warn, error)",
          "default": "info"
        },
        "DATABASE_URL": {
          "description": "PostgreSQL connection string (auto-set by Railway)",
          "reference": {
            "service": "postgres",
            "property": "DATABASE_URL"
          }
        },
        "BACKUP_ENABLED": {
          "description": "Enable automated backups",
          "default": "true"
        },
        "BACKUP_SCHEDULE": {
          "description": "Backup schedule (daily, weekly)",
          "default": "daily"
        },
        "BACKUP_RETENTION_DAYS": {
          "description": "Number of days to retain backups",
          "default": "30"
        },
        "SENTRY_DSN": {
          "description": "Sentry DSN for error monitoring (optional)",
          "default": ""
        }
      },
      "healthcheck": {
        "path": "/api/v1/health",
        "interval": 30,
        "timeout": 10
      },
      "replicas": 1
    },
    {
      "name": "postgres",
      "image": "postgres:16-alpine",
      "env": {
        "POSTGRES_DB": {
          "default": "versus_db"
        },
        "POSTGRES_USER": {
          "default": "versus_user"
        },
        "POSTGRES_PASSWORD": {
          "generator": {
            "type": "SECRET",
            "length": 32
          }
        }
      },
      "volumes": [
        {
          "name": "postgres-data",
          "mountPath": "/var/lib/postgresql/data"
        }
      ],
      "healthcheck": {
        "command": [
          "CMD-SHELL",
          "pg_isready -U $POSTGRES_USER -d $POSTGRES_DB"
        ],
        "interval": 10,
        "timeout": 5,
        "retries": 5
      }
    }
  ]
}
